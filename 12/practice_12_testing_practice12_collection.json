	"item": [
		{
			"name": "Get Product List",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test("Статус ответа 200 OK", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test("Ответ является массивом товаров", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.be.an('array');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/v1/products",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"v1",
						"products"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create New Order",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test("Статус ответа 201 Created", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test("Проверка наличия ID заказа и статуса NEW", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('id');",
							"    pm.expect(jsonData.status).to.eql('NEW');",
							"    pm.environment.set("current_order_id", jsonData.id);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"customerId\": 42,\n    \"items\": [\n        {\n            \"productId\": 101,\n            \"quantity\": 2\n        }\n    ]\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/v1/orders",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"v1",
						"orders"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Order Status",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test("Статус ответа 200 OK", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test("Проверка структуры объекта заказа", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('id');",
							"    pm.expect(jsonData).to.have.property('totalAmount');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/v1/orders/{{current_order_id}}",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"v1",
						"orders",
						"{{current_order_id}}"
					]
				}
			},
			"response": []
		}
	]
