{
  "name": "Spring Boot High Error Rate (>1%)",
  "interval": "1m",
  "rules": [
    {
      "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m])) * 100 > 1",
      "for": "2m",
      "labels": {
        "severity": "critical"
      },
      "annotations": {
        "summary": "Высокий уровень ошибок в приложении {{ $labels.application }}",
        "description": "Текущий уровень ошибок составляет {{ $value | printf \"%.2f\" }}%, что превышает допустимый порог в 1%."
      }
    }
  ]
}